<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="768.0" prefWidth="1366.0" styleClass="root-dashboard" stylesheets="@styles/Styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tek.dataproject.FXMLControllers.DashboardController">

   <bottom>
      <ButtonBar prefHeight="162.0" prefWidth="1451.0" BorderPane.alignment="CENTER" maxWidth="Infinity">
         <buttons>
            <ProgressBar fx:id="progressBar" prefHeight="51.0" prefWidth="200.0" progress="0.0" />
            <Slider fx:id="slider1" maxHeight="-Infinity" minHeight="-Infinity" minWidth="-Infinity" orientation="VERTICAL" prefHeight="114.0" />
            <Slider fx:id="slider2" maxHeight="-Infinity" minHeight="-Infinity" minWidth="63.0" orientation="VERTICAL" prefHeight="114.0" />
            <ProgressIndicator fx:id="progressIndicator" prefHeight="205.0" progress="0.0" />
            <Button fx:id="generateRandomPlanet" mnemonicParsing="false" onAction="#handleRandomPlanet" prefHeight="69.0" text="Random System" />
            <ToggleButton fx:id="toggleButton" mnemonicParsing="false" prefHeight="99.0" text="ToggleButton" />
            <Button fx:id="button2" mnemonicParsing="false" prefHeight="23.0" text="Button" />
            <ChoiceBox fx:id="choiceBox" prefWidth="150.0" />
         </buttons>
      </ButtonBar>
   </bottom>
    <center>
        <StackPane fx:id="systemPane" maxHeight="Infinity" maxWidth="Infinity" style="-fx-background-image: url('/com/tek/dataproject/images/MainPanel.jpg'); -fx-background-size: cover; -fx-background-position: center;">
        </StackPane>
    </center>
   <top>
      <TextFlow maxWidth="Infinity" prefHeight="112.0" prefWidth="1152.0" styleClass="TopPanel" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="urlLabel" prefHeight="35.0" prefWidth="106.0" text="Label" />
            <Hyperlink fx:id="hyperLink" prefHeight="33.0" prefWidth="451.0" text="Hyperlink" />
            <Label fx:id="planetNameLabel" prefHeight="44.0" prefWidth="107.0" text="Planet Name:" />
             <Label fx:id="planetNameDisplay" prefHeight="46.0" prefWidth="254.0" text="Pick a planet" />
            <Label fx:id="hoststarlabel" prefHeight="49.0" prefWidth="130.0" text="Host Star Name:" />
             <Label fx:id="hostStarNameDisplay" prefHeight="51.0" prefWidth="147.0" text="Pick a planet" />
         </children>
      </TextFlow>
   </top>
   <right>
      <SplitPane maxHeight="Infinity" dividerPositions="0.5" orientation="VERTICAL" prefHeight="272.0" prefWidth="296.0" styleClass="SplitPane" BorderPane.alignment="CENTER">
        <items>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="100.0" prefWidth="160.0">
               <children>
                   <StackedAreaChart fx:id="stackedAreaChart" layoutY="-2.0" prefHeight="277.0" prefWidth="295.0">
                       <xAxis>
                           <CategoryAxis side="BOTTOM" />
                       </xAxis>
                       <yAxis>
                           <NumberAxis side="LEFT" />
                       </yAxis>
                   </StackedAreaChart>
               </children>
            </AnchorPane>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="384.0" prefWidth="435.0">
               <children>
                  <Canvas height="200.0" layoutX="47.0" layoutY="51.0" width="200.0" />
                  <BarChart styleClass="barChart" fx:id="barChart" prefHeight="284.0" prefWidth="296.0">
                      <xAxis>
                          <CategoryAxis tickLabelRotation="45" />ki
                      </xAxis>
                      <yAxis>
                          <NumberAxis label="Travel Time (10^n Years)" tickLabelRotation="0" />
                      </yAxis>
                  </BarChart>
               </children>
            </AnchorPane>
        </items>
      </SplitPane>
   </right>
   <left>
       <VBox maxHeight="Infinity" prefHeight="604.0" prefWidth="283.0" spacing="10.0" styleClass="leftVbox" BorderPane.alignment="CENTER">
         <children>

             <Label prefHeight="38.0" prefWidth="296.0" styleClass="filterTitle" text="Filters:" />
             <Label text="Planet Type" styleClass="filterLabel" />
             <ComboBox prefWidth="150.0" fx:id="planetTypeComboBox" styleClass="filterBox" />
             <Label text="Discovery Method" styleClass="filterLabel" />
             <ComboBox prefWidth="150.0" fx:id="discoveryMethodComboBox" styleClass="filterBox" />
             <ToggleButton mnemonicParsing="false" text="Habitable" fx:id="habitableToggle" styleClass="smallToggle" />
             <Button mnemonicParsing="false" onAction="#handleApplyFilters" text="Apply Filters" fx:id="applyFiltersButton" styleClass="orangeButton" />
             <Button mnemonicParsing="false" onAction="#handleClearFilters" text="Clear Filters" fx:id="clearFiltersButton" styleClass="darkButton" />

         </children></VBox>
   </left>
</BorderPane>
